# Local dev:
# - Android emulator: http://10.0.2.2:3000
# - Physical device: http://<your-lan-ip>:3000, example http://192.168.1.38:3000
# - Production/demo build: https://api.binchat.me
EXPO_PUBLIC_API_URL=https://api.binchat.me
EXPO_PUBLIC_SOCKET_URL=https://api.binchat.me

# Optional local workaround for Expo CLI cache issues on some Node versions.
EXPO_NO_CACHE=1
